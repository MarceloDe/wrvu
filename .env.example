# --- Anthropic (the "intelligence") ---
# Get a key at https://console.anthropic.com  → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# Optional: override the model. Verify the current id in your Anthropic console.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Vercel KV (database) ---
# These are added AUTOMATICALLY when you create a KV store in the Vercel
# dashboard (Storage → Create Database → KV) and link it to this project.
# You normally do NOT paste these by hand.
KV_REST_API_URL=
KV_REST_API_TOKEN=
