# =========================================================================
# NeuroRVU environment variables
# In production these are injected by the Vercel Marketplace integrations
# (Clerk + Neon) — you normally pull them with `vercel env pull .env.local`.
# =========================================================================

# --- Anthropic (the "intelligence") ---
# Get a key at https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# Optional: override the model. Verify the current id in your Anthropic console.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Clerk (authentication) ---
# Injected automatically by the Clerk Vercel Marketplace integration.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_xxx
CLERK_SECRET_KEY=sk_xxx
# Keep the Clerk UI routes pointed at our custom pages:
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/app

# --- Neon Postgres (database) ---
# Injected automatically by the Neon Vercel Marketplace integration.
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# --- App admin ---
# Comma-separated emails that get admin (user management) access out of the box.
ADMIN_EMAILS=mocfelix@gmail.com
